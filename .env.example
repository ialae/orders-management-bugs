# =============================================================================
# Orders Management — Environment Variables
# =============================================================================


# -------
# Backend
# -------

# postgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@db:5432/orders_db

# comma separated list of allowed frontend origins
# Default: http://localhost:5173
# Example: http://localhost:5173,https://myapp.com
CORS_ORIGINS=http://localhost:5173

# Not currently used by the application, just reserved for future use
# SECRET_KEY=dev-secret-please-change-12345