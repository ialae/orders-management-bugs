# PostgreSQL database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=orders_db

# Backend API base URL (used by the frontend Vite dev server)
VITE_API_URL=http://localhost:8000

# Set to true to seed the database with sample data on startup (dev only)
AUTO_SEED=true

# CORS: exact origin allowed by the backend API
FRONTEND_ORIGIN=http://localhost:5173
# CORS: regex pattern for allowed origins (covers Docker network IPs)
FRONTEND_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1|172\.(1[6-9]|2[0-9]|3[0-1])\.\d+\.\d+):5173